# ─── Healthy-E Apache Configuration ──────────────────────────────────────────

# ── Error pages ──────────────────────────────────────────────────────────────
ErrorDocument 404 /404.html

# ── Directory index ──────────────────────────────────────────────────────────
DirectoryIndex index.html

# ── Security headers ─────────────────────────────────────────────────────────
# Standard: NIST SP 800-131A, OWASP Secure Headers Project, PCI DSS Req. 6.4
<IfModule mod_headers.c>

  # Prevent MIME-type sniffing attacks (OWASP A05:2021)
  Header always set X-Content-Type-Options    "nosniff"

  # Prevent clickjacking (OWASP A05:2021)
  Header always set X-Frame-Options           "SAMEORIGIN"

  # Legacy XSS filter (belt-and-suspenders for older browsers)
  Header always set X-XSS-Protection          "1; mode=block"

  # Limit referrer info sent to third parties (privacy)
  Header always set Referrer-Policy           "strict-origin-when-cross-origin"

  # Restrict device sensor APIs (privacy — CCPA §1798.140)
  Header always set Permissions-Policy \
    "camera=(), microphone=(), geolocation=(), payment=(self), usb=(), serial=(), bluetooth=()"

  # HTTP Strict Transport Security — force HTTPS for 1 year (PCI DSS Req. 4.2)
  # Uncomment when SSL certificate is live:
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Content-Security-Policy
  # Allows: Google Fonts, YouTube, Formspree (newsletter), Stripe (payments)
  # Blocks: inline eval(), data: URIs in scripts, unknown origins
  Header always set Content-Security-Policy "\
    default-src 'self'; \
    script-src 'self' 'unsafe-inline' \
      https://www.youtube.com https://s.ytimg.com \
      https://js.stripe.com https://checkout.stripe.com; \
    style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
    font-src 'self' https://fonts.gstatic.com; \
    img-src 'self' data: blob: https://i.ytimg.com https://yt3.ggpht.com; \
    frame-src \
      https://www.youtube.com https://www.youtube-nocookie.com \
      https://js.stripe.com https://hooks.stripe.com; \
    connect-src 'self' \
      https://www.youtube.com \
      https://formspree.io \
      https://api.stripe.com; \
    media-src 'self' blob: https://www.youtube.com; \
    form-action 'self' https://formspree.io; \
    base-uri 'self'; \
    upgrade-insecure-requests;"

  # Cross-Origin policies (prevent Spectre-style attacks on shared memory)
  Header always set Cross-Origin-Opener-Policy    "same-origin-allow-popups"
  Header always set Cross-Origin-Resource-Policy  "same-site"

  # Remove server fingerprint info
  Header always unset X-Powered-By
  Header always unset Server

</IfModule>

# ── HTTPS redirect (enable when SSL is live) ─────────────────────────────────
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTPS} off
#   RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# ── www → non-www redirect (enable when DNS is set) ──────────────────────────
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
#   RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
# </IfModule>

# ── GZIP compression ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml application/manifest+json
</IfModule>

# ── Browser caching ──────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — no cache (always fresh)
  ExpiresByType text/html                    "access plus 0 seconds"

  # CSS / JS — 1 week
  ExpiresByType text/css                     "access plus 1 week"
  ExpiresByType application/javascript       "access plus 1 week"

  # Images — 1 month
  ExpiresByType image/png                    "access plus 1 month"
  ExpiresByType image/jpeg                   "access plus 1 month"
  ExpiresByType image/webp                   "access plus 1 month"
  ExpiresByType image/gif                    "access plus 1 month"
  ExpiresByType image/svg+xml               "access plus 1 month"
  ExpiresByType image/x-icon               "access plus 1 year"

  # Fonts — 1 year
  ExpiresByType font/woff2                   "access plus 1 year"
  ExpiresByType font/woff                    "access plus 1 year"

  # Manifest — 1 day
  ExpiresByType application/manifest+json    "access plus 1 day"
</IfModule>

# ── Block access to sensitive files ──────────────────────────────────────────
<FilesMatch "\.(env|log|mjs|json|md|gitignore|htaccess)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Block direct browsing of security module source (still loadable by HTML <script> tags)
# This prevents attackers from studying the security implementation via the browser
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Allow script tags to load security/*.js (header Sec-Fetch-Dest: script)
  # Block direct browser navigation (Sec-Fetch-Dest: document)
  RewriteCond %{HTTP:Sec-Fetch-Dest} ^document$ [NC]
  RewriteRule ^security/.*\.js$  /404.html [R=404,L]
</IfModule>

# Allow specific JSON files needed by the browser
<Files "site.webmanifest">
  <IfModule mod_authz_core.c>
    Require all granted
  </IfModule>
</Files>

# ── Block directory listing ───────────────────────────────────────────────────
Options -Indexes
